{
    "network": [
        {
            "n_neurons": 200,
            "firing_threshold": 400,
            "w_init_normal": true,
            "w_init_mean": 0.3,
            "w_init_std": 0.01,
            "w_norm": true,
            "w_min": 0,
            "w_max": 1
        }
    ],
    "optimizer": {
        "method": "s2stdp",
        "stdp": "additive",
        "class_inhib": true,
        "t_gap": 0.005,
        "ap": 0.1,
        "am": -0.05,
        "annealing": 0.98
    },
    "regularizer": {
        "thr_lr": 5,
        "thr_anneal": 0.5
    },
    "trainer": {
        "epochs": 30,
        "nt_neurons": 1,
        "early_stopping": 5,
        "dynamic_activation": {
            "update_threshold": 120,
            "growth_after_epoch": 1,
            "uncertainty_margin": 0.12,
            "max_active_per_class": 18,
            "max_growth_per_class_per_epoch": 2,
            "max_growth_classes_per_epoch": 7,
            "min_class_difficulty_for_growth": 0.1,
            "class_error_weight": 1.0,
            "class_uncertainty_weight": 1.0
        },
        "pruning": {
            "enabled": true,
            "every_n_epochs": 3,
            "min_target_updates": 30,
            "min_target_updates_fraction": 0.2,
            "min_target_precision": 0.15,
            "max_prune_per_class": 1,
            "keep_min_active_per_class": 4,
            "class_difficulty_bias": 0.25
        }
    }
}
